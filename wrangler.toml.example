# Cloudflare Workers + Pages 混合部署配置
# 架构：Workers 提供 API + D1 存储 + Pages 托管静态文件

name = "profile-page"
main = "workers.js"
compatibility_date = "2024-09-19"

# D1 数据库绑定
# 注意：database_id 需要从 Cloudflare Dashboard 获取
# 运行：wrangler d1 create profile-page-db
[[d1_databases]]
binding = "PROFILE_DB"
database_name = "profile-page-db"
database_id = "YOUR_DATABASE_ID_HERE"  # ← 替换为你的数据库 ID

# 环境变量
[vars]
ENVIRONMENT = "dev"
PROFILE_PAGE_TITLE = "Your Profile Page"

# 开发环境配置
[env.dev]
name = "profile-page-dev"
[env.dev.vars]
ENVIRONMENT = "dev"

# 生产环境配置
[env.production]
name = "profile-page-prod"
[env.production.vars]
ENVIRONMENT = "production"

# 部署说明：
# 1. 创建 D1 数据库：wrangler d1 create profile-page-db
# 2. 复制 database_id 到上方配置
# 3. 初始化数据库：wrangler d1 execute profile-page-db --remote --file=d1-schema.sql
# 4. 部署：wrangler deploy --env production

# 注意：此文件不应包含敏感信息
# 实际的 wrangler.toml 已在 .gitignore 中忽略
